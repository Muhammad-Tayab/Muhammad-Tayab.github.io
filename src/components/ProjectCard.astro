---
export interface Props {
  title: string;
  excerpt: string;
  stack: string[];
  github?: string;
  liveUrl?: string;
  status: 'live' | 'coming-soon';
  featured?: boolean;
  slug?: string;
}

const { title, excerpt, stack, github, liveUrl, status, slug } = Astro.props;
const isComingSoon = status === 'coming-soon';
---
<article class={`project-card glass-card ${isComingSoon ? 'coming-soon' : ''}`}>
  <!-- Terminal title bar -->
  <div class="card-chrome">
    <div class="chrome-dots">
      <span class="dot-r"></span>
      <span class="dot-y"></span>
      <span class="dot-g"></span>
    </div>
    <span class="card-filename">{isComingSoon ? '[REDACTED]' : `~/${title.toLowerCase().replace(/\s+/g, '-')}`}</span>
    {isComingSoon
      ? <span class="status-badge coming">COMING SOON</span>
      : <span class="status-badge live">LIVE</span>
    }
  </div>

  <div class="card-body">
    <h3 class="card-title">
      {isComingSoon
        ? <span class="redacted">{title}</span>
        : title
      }
    </h3>
    <p class="card-excerpt">{isComingSoon ? '████████ ██████ ███████ ████████████ ██████████.' : excerpt}</p>

    <div class="card-stack">
      {stack.map(s => <span class="tag">{s}</span>)}
    </div>

    {!isComingSoon && (
      <div class="card-links">
        {github && (
          <a href={github} target="_blank" rel="noopener" class="card-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        )}
        {liveUrl && (
          <a href={liveUrl} target="_blank" rel="noopener" class="card-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
            Live
          </a>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .project-card.coming-soon {
    opacity: 0.55;
    filter: grayscale(0.3);
    position: relative;
  }

  .project-card.coming-soon::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 10px,
      rgba(255,34,0,0.03) 10px,
      rgba(255,34,0,0.03) 20px
    );
    pointer-events: none;
    border-radius: 8px;
  }

  /* Chrome bar */
  .card-chrome {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--glass-border);
  }

  .chrome-dots {
    display: flex;
    gap: 5px;
  }

  .dot-r, .dot-y, .dot-g {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot-r { background: rgba(255,95,87,0.5); }
  .dot-y { background: rgba(255,189,46,0.5); }
  .dot-g { background: rgba(40,202,66,0.5); }

  .card-filename {
    flex: 1;
    font-size: 0.7rem;
    opacity: 0.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-badge {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .status-badge.live {
    background: var(--green-dim);
    color: var(--green);
    border: 1px solid rgba(0,255,65,0.2);
  }

  .status-badge.coming {
    background: var(--red-dim);
    color: var(--red);
    border: 1px solid rgba(255,34,0,0.2);
  }

  /* Card body */
  .card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .card-title {
    font-size: 1.05rem;
    color: var(--white);
    line-height: 1.3;
  }

  .redacted {
    background: rgba(255,34,0,0.2);
    color: transparent;
    border-radius: 2px;
    user-select: none;
  }

  .card-excerpt {
    font-size: 0.82rem;
    opacity: 0.65;
    line-height: 1.6;
    flex: 1;
  }

  .card-stack {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .card-links {
    display: flex;
    gap: 12px;
    margin-top: 4px;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--green);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    border: 1px solid rgba(0,255,65,0.25);
    padding: 5px 12px;
    border-radius: 4px;
    transition: background 0.2s, box-shadow 0.2s;
    opacity: 0.9;
  }

  .card-link:hover {
    background: var(--green-dim);
    box-shadow: 0 0 10px var(--green-glow);
    opacity: 1;
  }
</style>
