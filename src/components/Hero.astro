---
---
<div class="term-card">
  <!-- Terminal window chrome -->
  <div class="terminal-chrome">
    <div class="chrome-dots">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    <span class="chrome-title">bash — n16h70wl@kali: ~</span>
  </div>

  <div class="terminal-body">
    <div class="terminal-line">
      <span class="prompt">┌──(n16h70wl㉿kali)-[~]</span>
    </div>
    <div class="terminal-line">
      <span class="prompt">└─$ </span>
      <span class="typed-cmd" id="typedCmd"></span><span class="blink" id="cmdCursor"></span>
    </div>
    <div class="terminal-output" id="whoamiOutput" style="display:none;">
      <p><span class="green">N16H70WL</span></p>
    </div>
    <div class="terminal-line" id="roleLine" style="display:none;">
      <span class="prompt">└─$ </span>
      <span class="typed-role" id="typedRole"></span><span class="blink" id="roleCursor"></span>
    </div>
    <div class="terminal-output" id="roleOutput" style="display:none;">
      <p id="roleText"></p>
    </div>
  </div>
</div>

<style>
  .term-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--glass-border);
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    padding: 10px 16px;
  }

  .chrome-dots { display: flex; gap: 6px; }

  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot.red    { background: #FF5F57; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green  { background: #28CA42; }

  .chrome-title { font-size: 0.72rem; opacity: 0.4; letter-spacing: 0.05em; }

  .terminal-body {
    flex: 1;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid var(--glass-border);
    border-radius: 0 0 8px 8px;
    padding: 20px 22px;
    min-height: 160px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .terminal-line {
    display: flex;
    align-items: center;
    font-size: 0.9rem;
    margin-bottom: 4px;
  }

  .prompt { color: var(--green); white-space: pre; }
  .typed-cmd, .typed-role { color: var(--white); font-size: 0.9rem; }

  .terminal-output {
    padding: 8px 0 8px 16px;
    font-size: 0.9rem;
    border-left: 2px solid rgba(0, 255, 65, 0.3);
    margin: 6px 0 10px;
  }
</style>

<script>
  function typeText(el: HTMLElement, text: string, speed = 60): Promise<void> {
    return new Promise(resolve => {
      let i = 0;
      const timer = setInterval(() => {
        el.textContent += text[i++];
        if (i >= text.length) { clearInterval(timer); resolve(); }
      }, speed);
    });
  }

  async function runTerminal() {
    await new Promise(r => setTimeout(r, 600));

    const cmdEl = document.getElementById('typedCmd');
    const cmdCursor = document.getElementById('cmdCursor');
    const whoamiOutput = document.getElementById('whoamiOutput');
    const roleLine = document.getElementById('roleLine');
    const roleEl = document.getElementById('typedRole');
    const roleCursor = document.getElementById('roleCursor');
    const roleOutput = document.getElementById('roleOutput');
    const roleText = document.getElementById('roleText');
    if (!cmdEl || !roleEl || !roleText) return;

    await typeText(cmdEl, 'whoami', 100);
    await new Promise(r => setTimeout(r, 400));
    if (cmdCursor) cmdCursor.style.display = 'none';

    if (whoamiOutput) whoamiOutput.style.display = 'block';
    await new Promise(r => setTimeout(r, 600));

    if (roleLine) roleLine.style.display = 'flex';
    await typeText(roleEl, 'cat role.txt', 90);
    await new Promise(r => setTimeout(r, 400));
    if (roleCursor) roleCursor.style.display = 'none';

    if (roleOutput) roleOutput.style.display = 'block';
    roleText.innerHTML = '<span style="color:var(--green)">Penetration Tester</span> & Security Researcher';
  }

  runTerminal();
</script>
