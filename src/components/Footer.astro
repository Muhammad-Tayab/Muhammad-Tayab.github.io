const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="terminal-divider">
    ════════════════════════════════════════════════════════════════════
  </div>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="green">n16h70wl55</span>@kali<span class="dim">:~$</span>
      <span class="dim"> exit</span>
    </div>
    <div class="footer-links">
      <a href="mailto:tayyabbashir461@gmail.com" class="footer-link">email</a>
      <span class="dim">·</span>
      <a href="https://www.linkedin.com/in/muhammad-tayab-bashir-694b84125/" target="_blank" rel="noopener" class="footer-link">linkedin</a>
      <span class="dim">·</span>
      <a href="https://hackerone.com/n16h70wl55" target="_blank" rel="noopener" class="footer-link">hackerone</a>
      <span class="dim">·</span>
      <a href="/blog" class="footer-link">blog</a>
      <span class="dim">·</span>
      <a href="/ctf" class="footer-link">ctf</a>
    </div>
    <div class="footer-copy dim">
      <span>© {year} Muhammad Tayab Bashir</span>
      <span class="dot">·</span>
      <span>Built with Astro</span>
      <span class="dot">·</span>
      <span>No trackers. No cookies.</span>
    </div>
