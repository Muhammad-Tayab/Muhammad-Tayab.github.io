    {
      id:'bug-bounty-discovery', name:'Bug Bounty Program & Scope Discovery', engines:['Google','Bing'],
      insight:'Finding private / unlisted bug bounty programs gives you a less competitive attack surface. security.txt is the standard.',
      dorks:[
        {id:'bb1',label:'security.txt files',q:'site:{target} inurl:/.well-known/security.txt | inurl:/security.txt'},
        {id:'bb2',label:'Bug bounty & disclosure pages',q:'site:{target} intitle:"bug bounty" | intitle:"responsible disclosure" | intitle:"vulnerability disclosure"'},
        {id:'bb3',label:'HackerOne embedded forms',q:'"powered by hackerone" site:{target}'},
        {id:'bb4',label:'Bugcrowd embedded forms',q:'"powered by bugcrowd" site:{target}'},
        {id:'bb5',label:'PDF bounty policies',q:'site:{target} filetype:pdf intitle:"vulnerability disclosure policy" | intitle:"bug bounty"'},
        {id:'bb6',label:'Hall of fame (self-hosted)',q:'site:{target} intitle:"hall of fame" | intitle:"security researchers" | intitle:"acknowledgements"'},
        {id:'bb7',label:'Private program hints',q:'"apply to join" "private program" "{target}"'}
      ]
    }
  ];

  // Build a lookup: dork ID -> category ID (for finding the right engine)
  var dorkToCat = {};
  CATS.forEach(function(cat) {
    cat.dorks.forEach(function(d) { dorkToCat[d.id] = cat.id; });
  });

  var checked = {};
  var filterActive = false;

  function fillDork(q) {
    var t = document.getElementById('target-input').value.trim() || '{target}';
    return q.replace(/\{target\}/g, t);
  }

  function getSearch() { return document.getElementById('search-input').value.toLowerCase(); }
  function totalDorks() { var n=0; CATS.forEach(function(c){n+=c.dorks.length;}); return n; }
  function checkedCount() { var n=0; for(var k in checked){if(checked[k])n++;} return n; }

  // Get the correct engine for a category
  function getCatEngine(catId) {
    var cat = CATS.find(function(c){return c.id===catId;});
    return cat ? cat.engines[0] : 'Google';
  }

  // Get the correct engine for a dork by its ID
  function getDorkEngine(dorkId) {
    return getCatEngine(dorkToCat[dorkId]);
  }

  function updateProgress() {
    var tot = totalDorks(), done = checkedCount();
    var pct = tot ? Math.round(done/tot*100) : 0;
    document.getElementById('prog-fill').style.width = pct+'%';
    document.getElementById('prog-count').textContent = done + ' / ' + tot + ' complete';
    document.getElementById('stat-pct').textContent = pct+'%';
    document.getElementById('stat-total').textContent = tot;
    document.getElementById('stat-cats').textContent = CATS.length;
  }

  function toggleFilter() {
    filterActive = !filterActive;
    document.getElementById('filter-btn').classList.toggle('active', filterActive);
    render();
  }

  function resetAll() { checked = {}; filterActive = false; document.getElementById('filter-btn').classList.remove('active'); render(); }

  function copyDork(q, id) {
    navigator.clipboard.writeText(fillDork(q)).then(function() {
      var btn = document.getElementById('copy-'+id);
      if(!btn) return;
      btn.textContent = 'Copied';
      btn.classList.add('copied');
      setTimeout(function() { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
    });
  }

  function openDork(q, engine) {
    var fn = ENGINE_URLS[engine];
    if(fn) window.open(fn(fillDork(q)), '_blank');
  }

  // Open all checked dorks, each in its correct engine
  function openAllChecked() {
    var count = 0;
    CATS.forEach(function(cat) {
      var eng = cat.engines[0]; // primary engine for this category
      cat.dorks.forEach(function(d) {
        if(checked[d.id]) {
          count++;
          if(count <= 15) openDork(d.q, eng);
        }
      });
    });
    if(count > 15) alert('Opened first 15 tabs. Browser may block more popups.');
    if(count === 0) alert('No techniques checked. Check some first, then click Open Checked.');
  }

  function selectAllCat(catId) {
    var cat = CATS.find(function(c){return c.id===catId;});
    if(!cat) return;
    var allChecked = cat.dorks.every(function(d){return checked[d.id];});
    cat.dorks.forEach(function(d){ checked[d.id] = !allChecked; });
    render();
  }

  // Open all dorks in a category using that category's primary engine
  function openAllCat(catId) {
    var cat = CATS.find(function(c){return c.id===catId;});
    if(!cat) return;
    var eng = cat.engines[0];
    var count = 0;
    cat.dorks.forEach(function(d) {
      count++;
      if(count <= 10) openDork(d.q, eng);
    });
    if(count > 10) alert('Opened first 10. Browser may block more popups.');
  }

  function toggleCat(id) {
    var body = document.getElementById('body-'+id);
    var chev = document.getElementById('chev-'+id);
    if(!body) return;
    var isOpen = body.style.display !== 'none';
    body.style.display = isOpen ? 'none' : 'block';
    chev.classList.toggle('open', !isOpen);
  }

  function toggleCheck(id) {
    checked[id] = !checked[id];
    render();
  }

  function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function render() {
    var search = getSearch();
    var container = document.getElementById('categories');
    var html = '';

    CATS.forEach(function(cat) {
      var filtered = cat.dorks.filter(function(d) {
        var matchSearch = !search || d.label.toLowerCase().indexOf(search)!==-1 || d.q.toLowerCase().indexOf(search)!==-1;
        var matchFilter = !filterActive || !checked[d.id];
        return matchSearch && matchFilter;
      });
      if(!filtered.length) return;

      var catDone = cat.dorks.filter(function(d){return checked[d.id];}).length;
      var catPct = Math.round(catDone/cat.dorks.length*100);
      var allChecked = catDone === cat.dorks.length;
      var primaryEngine = cat.engines[0];

      var engTags = cat.engines.map(function(e) {
        var c = ENGINE_COLORS[e] || '#888';
        return '<span class="eng-tag" style="background:'+c+'18;color:'+c+';border:1px solid '+c+'44">'+e+'</span>';
      }).join('');

      var dorkRows = filtered.map(function(d) {
        var done = checked[d.id];
        var filled = escapeHtml(fillDork(d.q));
        // Each dork's Open button uses its category's primary engine
        return '<div class="dork-row'+(done?' done':'')+'" id="row-'+d.id+'">' +
          '<input type="checkbox" class="dork-check" '+(done?'checked':'')+' data-dork-id="'+d.id+'"/>' +
          '<div class="dork-info">' +
            '<div class="dork-label">'+escapeHtml(d.label)+'</div>' +
            '<div class="dork-query">'+filled+'</div>' +
          '</div>' +
          '<div class="dork-actions">' +
            '<button class="dork-btn" id="copy-'+d.id+'" data-copy-q="'+escapeHtml(d.q)+'" data-copy-id="'+d.id+'">Copy</button>' +
            '<button class="dork-btn open-btn" data-open-q="'+escapeHtml(d.q)+'" data-open-eng="'+primaryEngine+'">Open in '+primaryEngine+'</button>' +
          '</div>' +
        '</div>';
      }).join('');

      html += '<div class="cat-card">' +
        '<div class="cat-header" data-cat-toggle="'+cat.id+'">' +
          '<span class="cat-name">'+cat.name+'</span>' +
          '<div class="cat-engines">'+engTags+'</div>' +
          '<span class="cat-prog">'+catDone+'/'+cat.dorks.length+'</span>' +
          '<span class="cat-chevron open" id="chev-'+cat.id+'">&#9650;</span>' +
        '</div>' +
        '<div class="cat-body" id="body-'+cat.id+'">' +
          '<div class="cat-actions">' +
            '<button class="cat-action-btn" data-select-all="'+cat.id+'">'+(allChecked?'Deselect All':'Select All')+'</button>' +
            '<button class="cat-action-btn open-cat" data-open-all="'+cat.id+'">Open All in '+primaryEngine+'</button>' +
          '</div>' +
          '<div class="cat-insight"><span class="cat-insight-icon">&#9432;</span>'+cat.insight+'</div>' +
          '<div class="cat-subprog"><div class="cat-subprog-fill" style="width:'+catPct+'%"></div></div>' +
          dorkRows +
        '</div>' +
      '</div>';
    });

    container.innerHTML = html;
    bindEvents();
    updateProgress();
  }

  function bindEvents() {
    document.querySelectorAll('[data-cat-toggle]').forEach(function(el) {
      el.addEventListener('click', function() { toggleCat(this.getAttribute('data-cat-toggle')); });
    });

    document.querySelectorAll('[data-dork-id]').forEach(function(el) {
      el.addEventListener('change', function() { toggleCheck(this.getAttribute('data-dork-id')); });
    });

    document.querySelectorAll('[data-copy-q]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        copyDork(this.getAttribute('data-copy-q'), this.getAttribute('data-copy-id'));
      });
    });

    // Open buttons now carry their engine in data-open-eng
    document.querySelectorAll('[data-open-q]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        openDork(this.getAttribute('data-open-q'), this.getAttribute('data-open-eng'));
      });
    });

    document.querySelectorAll('[data-select-all]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        selectAllCat(this.getAttribute('data-select-all'));
      });
    });

    document.querySelectorAll('[data-open-all]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        openAllCat(this.getAttribute('data-open-all'));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    render();
    document.getElementById('target-input').addEventListener('input', render);
    document.getElementById('search-input').addEventListener('input', render);
    document.getElementById('filter-btn').addEventListener('click', toggleFilter);
    document.getElementById('reset-btn').addEventListener('click', resetAll);
    document.getElementById('open-checked-btn').addEventListener('click', openAllChecked);
  });
})();
</script>
