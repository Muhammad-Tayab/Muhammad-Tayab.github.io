let checked = {};
let filterActive = false;

function fillDork(q) {
  const t = document.getElementById('target-input').value.trim() || '{target}';
  return q.replace(/\{target\}/g, t);
}

function getEngine() { return document.getElementById('engine-select').value; }
function getSearch() { return document.getElementById('search-input').value.toLowerCase(); }
function totalDorks() { return CATS.reduce((a,c) => a + c.dorks.length, 0); }
function checkedCount() { return Object.values(checked).filter(Boolean).length; }

function updateProgress() {
  const tot = totalDorks(), done = checkedCount();
  const pct = tot ? Math.round(done/tot*100) : 0;
  document.getElementById('prog-fill').style.width = pct+'%';
  document.getElementById('prog-count').textContent = `${done} / ${tot} complete`;
  document.getElementById('stat-pct').textContent = pct+'%';
  document.getElementById('stat-total').textContent = tot;
  document.getElementById('stat-cats').textContent = CATS.length;
}

function toggleFilter() {
  filterActive = !filterActive;
  document.getElementById('filter-btn').classList.toggle('active', filterActive);
  render();
}

function resetAll() { checked = {}; render(); updateProgress(); }

function copyDork(q, id) {
  navigator.clipboard.writeText(fillDork(q)).then(() => {
    const btn = document.getElementById('copy-'+id);
    if(!btn) return;
    const orig = btn.textContent;
    btn.textContent = 'Copied';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1500);
  });
}

function openDork(q) {
  const eng = getEngine();
  const url = ENGINE_URLS[eng]?.(fillDork(q));
  if(url) window.open(url,'_blank');
}

function toggleCat(id) {
  const body = document.getElementById('body-'+id);
  const chev = document.getElementById('chev-'+id);
  if(!body) return;
  const open = body.style.display !== 'none';
  body.style.display = open ? 'none' : 'block';
  chev.classList.toggle('open', !open);
}

function toggleCheck(id) {
  checked[id] = !checked[id];
  render();
}

function render() {
  const search = getSearch();
  const container = document.getElementById('categories');
  container.innerHTML = '';

  CATS.forEach(cat => {
    const filtered = cat.dorks.filter(d => {
      const matchSearch = !search || d.label.toLowerCase().includes(search) || d.q.toLowerCase().includes(search);
      const matchFilter = !filterActive || !checked[d.id];
      return matchSearch && matchFilter;
    });
    if(!filtered.length) return;

    const catDone = cat.dorks.filter(d => checked[d.id]).length;
    const catPct = Math.round(catDone/cat.dorks.length*100);

    const engTags = cat.engines.map(e => {
      const c = ENGINE_COLORS[e] || '#888';
      return `<span class="eng-tag" style="background:${c}18;color:${c};border:1px solid ${c}44">${e}</span>`;
    }).join('');

    const dorkRows = filtered.map(d => {
      const done = checked[d.id];
      const filled = fillDork(d.q);
      const escapedQ = d.q.replace(/'/g, "\\'");
      return `<div class="dork-row${done?' done':''}" id="row-${d.id}">
        <input type="checkbox" class="dork-check" ${done?'checked':''} onchange="toggleCheck('${d.id}')"/>
        <div class="dork-info">
          <div class="dork-label">${d.label}</div>
          <div class="dork-query">${filled}</div>
        </div>
        <div class="dork-actions">
          <button class="dork-btn" id="copy-${d.id}" onclick="copyDork('${escapedQ}','${d.id}')">Copy</button>
          <button class="dork-btn open-btn" onclick="openDork('${escapedQ}')">Open</button>
        </div>
      </div>`;
    }).join('');

    container.innerHTML += `
      <div class="cat-card">
        <div class="cat-header" onclick="toggleCat('${cat.id}')">
          <span class="cat-name">${cat.name}</span>
          <div class="cat-engines">${engTags}</div>
          <span class="cat-prog">${catDone}/${cat.dorks.length}</span>
          <span class="cat-chevron open" id="chev-${cat.id}">&#9650;</span>
        </div>
        <div class="cat-body" id="body-${cat.id}">
          <div class="cat-insight"><span class="cat-insight-icon">&#9432;</span>${cat.insight}</div>
          <div class="cat-subprog"><div class="cat-subprog-fill" style="width:${catPct}%"></div></div>
          ${dorkRows}
        </div>
      </div>`;
  });
  updateProgress();
}

document.addEventListener('DOMContentLoaded', () => {
  render();
  document.getElementById('target-input').addEventListener('input', render);
  document.getElementById('search-input').addEventListener('input', render);
  document.getElementById('engine-select').addEventListener('change', render);
});
</script>
