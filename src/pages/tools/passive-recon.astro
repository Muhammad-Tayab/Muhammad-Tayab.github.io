---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout title="Passive Recon Intelligence Engine | Tayab Bashir" description="A structured dorking and OSINT checklist covering Google, Bing, Shodan, FOFA, Censys, GreyNoise, GitHub, GitLab and more — built for bug bounty hunters and penetration testers.">
  <Nav />
  <main class="recon-main">

    <!-- ══════ HERO ══════ -->
    <section class="recon-hero reveal">
      <div class="hero-eyebrow"><span class="green">$</span> cat /opt/tools/passive-recon.txt</div>
      <h1 class="hero-title">
        <span class="green">// </span>Passive Recon<br/>
        <span class="dim">Intelligence Engine</span>
      </h1>
      <p class="hero-desc">
        A structured dorking and OSINT checklist covering Google, Bing, Yandex, Shodan, FOFA, Censys, GreyNoise, GitHub, GitLab, and more — built for bug bounty hunters and penetration testers who want systematic, reproducible passive recon.
      </p>
      <div class="hero-stats">
        <div class="stat-box glass-card">
          <span class="stat-num green" id="stat-total">0</span>
          <span class="stat-label">Techniques</span>
        </div>
        <div class="stat-box glass-card">
          <span class="stat-num green" id="stat-cats">0</span>
          <span class="stat-label">Categories</span>
        </div>
        <div class="stat-box glass-card">
          <span class="stat-num green">12+</span>
          <span class="stat-label">Engines</span>
        </div>
        <div class="stat-box glass-card">
          <span class="stat-num green" id="stat-pct">0%</span>
          <span class="stat-label">Complete</span>
        </div>
      </div>
    </section>

    <div class="terminal-divider">════════════════════════════════════════════════════</div>

    <!-- ══════ TOOL INTERFACE ══════ -->
    <section class="recon-tool reveal">

      <!-- Target bar -->
      <div class="target-bar glass-card">
        <div class="target-row">
          <label class="target-label"><span class="green">$</span> target</label>
          <input id="target-input" class="target-input" placeholder="example.com" spellcheck="false" />
        </div>
        <div class="target-row">
          <label class="target-label"><span class="green">$</span> engine</label>
          <select id="engine-select" class="target-select">
            <option>Google</option>
            <option>Bing</option>
            <option>Yandex</option>
            <option>DuckDuckGo</option>
            <option>Shodan</option>
            <option>FOFA</option>
            <option>Censys</option>
            <option>GreyNoise</option>
            <option>GitHub</option>
            <option>GitLab</option>
            <option>Grep.app</option>
            <option>IntelX</option>
          </select>
        </div>
        <div class="target-row">
          <label class="target-label"><span class="green">$</span> grep</label>
          <input id="search-input" class="target-input" placeholder="Filter techniques…" spellcheck="false" />
        </div>
        <div class="target-actions">
          <button id="filter-btn" class="action-btn" onclick="toggleFilter()">unchecked only</button>
          <button class="action-btn reset" onclick="resetAll()">↺ reset</button>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="progress-wrap reveal">
        <div class="progress-meta">
          <span class="progress-label"><span class="green">$</span> progress --session</span>
          <span class="progress-count green" id="prog-count">0 / 0 complete</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill" id="prog-fill" style="width:0%"></div>
        </div>
      </div>

      <!-- Categories -->
      <div id="categories" class="categories"></div>

    </section>

    <!-- ══════ DISCLAIMER ══════ -->
    <section class="disclaimer reveal">
      <div class="disclaimer-box glass-card">
        <span class="red">⚠</span>
        <span>Authorized security research only — always stay in scope. This tool generates search queries; it does not interact with any target systems.</span>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .recon-main {
    padding-top: 80px;
    min-height: 100vh;
  }

  /* ── Hero ── */
  .recon-hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px 48px;
  }

  .hero-eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(224, 224, 224, 0.5);
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.15;
    color: var(--white);
    margin-bottom: 20px;
  }

  .hero-desc {
    font-size: 0.88rem;
    color: rgba(224, 224, 224, 0.65);
    max-width: 700px;
    line-height: 1.8;
    margin-bottom: 36px;
  }

  .hero-stats {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .stat-box {
    padding: 16px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    min-width: 100px;
  }

  .stat-num {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  /* ── Tool section ── */
  .recon-tool {
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px 24px 48px;
  }

  /* ── Target bar ── */
  .target-bar {
    padding: 20px 24px;
    margin-bottom: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .target-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 200px;
  }

  .target-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(224, 224, 224, 0.5);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .target-input,
  .target-select {
    flex: 1;
    font-family: var(--font);
    font-size: 0.82rem;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--glass-border);
    border-radius: 4px;
    padding: 9px 14px;
    color: var(--green);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .target-input::placeholder {
    color: rgba(0, 255, 65, 0.25);
  }

  .target-input:focus,
  .target-select:focus {
    border-color: rgba(0, 255, 65, 0.4);
    box-shadow: 0 0 12px var(--green-glow);
  }

  .target-select option {
    background: #111;
    color: var(--green);
  }

  .target-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .action-btn {
    font-family: var(--font);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 9px 16px;
    border: 1px solid var(--glass-border);
    border-radius: 4px;
    background: transparent;
    color: rgba(224, 224, 224, 0.5);
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-btn:hover {
    border-color: rgba(0, 255, 65, 0.3);
    color: var(--green);
  }

  .action-btn.active {
    border-color: var(--green);
    color: var(--green);
    background: var(--green-dim);
  }

  .action-btn.reset:hover {
    border-color: rgba(255, 34, 0, 0.4);
    color: var(--red);
  }

  /* ── Progress ── */
  .progress-wrap {
    margin-bottom: 32px;
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .progress-label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(224, 224, 224, 0.4);
  }

  .progress-count {
    font-size: 0.75rem;
  }

  .progress-track {
    height: 3px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--green);
    border-radius: 2px;
    transition: width 0.4s ease;
    box-shadow: 0 0 8px var(--green-glow);
  }

  /* ── Categories ── */
  .categories {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Disclaimer ── */
  .disclaimer {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .disclaimer-box {
    padding: 14px 20px;
    font-size: 0.78rem;
    color: rgba(224, 224, 224, 0.55);
    display: flex;
    gap: 10px;
    align-items: center;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .target-bar {
      flex-direction: column;
    }
    .target-row {
      min-width: 100%;
    }
    .target-actions {
      width: 100%;
      justify-content: stretch;
    }
    .target-actions .action-btn {
      flex: 1;
    }
  }
</style>

<style is:global>
  /* ── Category cards ── */
  .cat-card {
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .cat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    cursor: pointer;
    background: rgba(0, 255, 65, 0.02);
    border-bottom: 1px solid transparent;
    user-select: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .cat-header:hover {
    background: rgba(0, 255, 65, 0.05);
  }

  .cat-name {
    flex: 1;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--white);
  }

  .cat-engines {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .eng-tag {
    font-family: var(--font);
    font-size: 0.58rem;
    padding: 2px 7px;
    border-radius: 3px;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .cat-prog {
    font-size: 0.72rem;
    color: rgba(224, 224, 224, 0.4);
    white-space: nowrap;
  }

  .cat-chevron {
    font-size: 0.6rem;
    color: var(--green);
    margin-left: 4px;
    transition: transform 0.25s;
    opacity: 0.6;
  }

  .cat-chevron.open {
    transform: rotate(180deg);
  }

  .cat-body {
    border-top: 1px solid var(--glass-border);
  }

  /* ── Insight box ── */
  .cat-insight {
    padding: 12px 20px;
    background: rgba(0, 255, 65, 0.03);
    border-bottom: 1px solid var(--glass-border);
    font-size: 0.75rem;
    color: rgba(224, 224, 224, 0.55);
    line-height: 1.7;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .cat-insight-icon {
    color: var(--green);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── Category sub-progress ── */
  .cat-subprog {
    height: 2px;
    background: rgba(255, 255, 255, 0.04);
    margin: 0 20px;
  }

  .cat-subprog-fill {
    height: 100%;
    background: var(--green);
    border-radius: 1px;
    transition: width 0.3s;
    box-shadow: 0 0 4px var(--green-glow);
  }

  /* ── Dork rows ── */
  .dork-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    transition: background 0.15s;
  }

  .dork-row:last-child {
    border-bottom: none;
  }

  .dork-row:hover {
    background: rgba(0, 255, 65, 0.03);
  }

  .dork-row.done {
    background: rgba(0, 255, 65, 0.04);
  }

  .dork-check {
    width: 16px;
    height: 16px;
    accent-color: var(--green);
    cursor: pointer;
    flex-shrink: 0;
  }

  .dork-info {
    flex: 1;
    min-width: 0;
  }

  .dork-label {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--white);
    opacity: 0.85;
  }

  .dork-row.done .dork-label {
    color: var(--green);
    text-decoration: line-through;
    text-decoration-color: rgba(0, 255, 65, 0.4);
    opacity: 0.7;
  }

  .dork-query {
    font-size: 0.65rem;
    color: rgba(0, 255, 65, 0.35);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
  }

  .dork-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .dork-btn {
    font-family: var(--font);
    font-size: 0.62rem;
    padding: 5px 10px;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid var(--glass-border);
    background: transparent;
    color: rgba(224, 224, 224, 0.45);
    transition: all 0.15s;
    white-space: nowrap;
  }

  .dork-btn:hover {
    border-color: rgba(0, 255, 65, 0.3);
    color: var(--green);
  }

  .dork-btn.copied {
    border-color: var(--green);
    color: var(--green);
    background: var(--green-dim);
  }

  .dork-btn.open-btn:hover {
    background: var(--green);
    color: var(--bg);
    border-color: var(--green);
  }

  @media (max-width: 768px) {
    .dork-query { display: none; }
    .cat-engines { display: none; }
    .dork-actions { gap: 4px; }
    .dork-btn { padding: 4px 8px; }
  }
</style>

<script>
const ENGINE_URLS = {
  Google: q => `https://www.google.com/search?q=${encodeURIComponent(q)}`,
  Bing: q => `https://www.bing.com/search?q=${encodeURIComponent(q)}`,
  Yandex: q => `https://yandex.com/search/?text=${encodeURIComponent(q)}`,
  DuckDuckGo: q => `https://duckduckgo.com/?q=${encodeURIComponent(q)}`,
  Shodan: q => `https://www.shodan.io/search?query=${encodeURIComponent(q)}`,
  FOFA: q => `https://en.fofa.info/result?qbase64=${btoa(q)}`,
  Censys: q => `https://search.censys.io/search?resource=hosts&q=${encodeURIComponent(q)}`,
  GreyNoise: q => `https://viz.greynoise.io/query/?gnql=${encodeURIComponent(q)}`,
  GitHub: q => `https://github.com/search?q=${encodeURIComponent(q)}&type=code`,
  GitLab: q => `https://gitlab.com/search?search=${encodeURIComponent(q)}&scope=blobs`,
  'Grep.app': q => `https://grep.app/search?q=${encodeURIComponent(q)}`,
  IntelX: q => `https://intelx.io/?s=${encodeURIComponent(q)}`,
};

const ENGINE_COLORS = {
  Google:'#4285F4',Bing:'#008373',Yandex:'#FF3B30',DuckDuckGo:'#DE5833',
  Shodan:'#D93025',FOFA:'#1A73E8',Censys:'#00897B',GreyNoise:'#546E7A',
  GitHub:'#6E40C9',GitLab:'#E24329','Grep.app':'#FF6B35',IntelX:'#00FF41'
};

const CATS = [
  {
    id:'google-dorks', name:'Google / Bing Dorking', engines:['Google','Bing','DuckDuckGo','Yandex'],
    insight:'The foundation of passive recon. Google dorking reveals exposed files, admin panels, error messages, and indexed secrets that have been crawled directly from the target. Combine multiple dorks for best results.',
    dorks:[
      {id:'g1',label:'All indexed subdomains',q:'site:*.{target}'},
      {id:'g2',label:'Nested subdomains (multi-level)',q:'site:*.*.{target}'},
      {id:'g3',label:'Staging / dev environments',q:'site:*.{target} inurl:staging | inurl:dev | inurl:test | inurl:uat | inurl:preprod'},
      {id:'g4',label:'Admin & login panels',q:'site:{target} inurl:admin | inurl:login | inurl:portal | inurl:dashboard'},
      {id:'g5',label:'Exposed config / env files',q:'site:{target} ext:env | ext:conf | ext:ini | ext:bak | ext:backup | ext:sh | ext:log'},
      {id:'g6',label:'Exposed office / PDF docs',q:'site:{target} ext:pdf | ext:doc | ext:docx | ext:xls | ext:xlsx | ext:ppt | ext:pptx'},
      {id:'g7',label:'SQL dumps & DB exports',q:'site:{target} ext:sql | ext:dump | ext:sql.gz intext:"INSERT INTO"'},
      {id:'g8',label:'Private keys & certificates',q:'site:{target} ext:pem | ext:key | ext:crt | ext:cer | ext:p12 | ext:pfx'},
      {id:'g9',label:'Open directory listings',q:'site:{target} intitle:"index of" "parent directory"'},
      {id:'g10',label:'Swagger / API docs exposed',q:'site:{target} inurl:swagger | inurl:api-docs | intitle:"Swagger UI" | inurl:/api/v1'},
      {id:'g11',label:'Exposed Kubernetes / Helm',q:'site:{target} ext:yaml | ext:yml intext:"apiVersion" | intext:"kind: Deployment"'},
      {id:'g12',label:'SQL error messages',q:'site:{target} intext:"sql syntax" | intext:"mysql_fetch" | intext:"ORA-" | intext:"SQLSTATE"'},
      {id:'g13',label:'Stack traces & exceptions',q:'site:{target} intitle:"exception" | intext:"stack trace" | intext:"unhandled exception"'},
      {id:'g14',label:'PHP / ASP debug errors',q:'site:{target} intext:"undefined index" | intext:"Warning: include" | intext:"Parse error"'},
      {id:'g15',label:'Redirect / SSRF params',q:'site:{target} inurl:url= | inurl:redirect= | inurl:next= | inurl:return= | inurl:redir= inurl:http'},
      {id:'g16',label:'Confidential / internal docs',q:'site:{target} intitle:"confidential" | intitle:"internal use only" | intitle:"restricted"'},
      {id:'g17',label:'Jenkins / CI dashboards',q:'site:{target} intitle:"Dashboard [Jenkins]" | inurl:jenkins'},
      {id:'g18',label:'Kibana / Grafana panels',q:'site:{target} inurl:kibana | inurl:grafana | intitle:"Grafana"'},
      {id:'g19',label:'Exposed phpMyAdmin',q:'site:{target} intitle:"phpMyAdmin" "Welcome to phpMyAdmin"'},
      {id:'g20',label:'WordPress config & admin',q:'site:{target} inurl:wp-config.php | inurl:wp-admin | inurl:wp-login.php'},
      {id:'g21',label:'Connection strings & DSNs',q:'site:{target} intext:"connectionString" | intext:"jdbc:mysql" | intext:"mongodb://" | intext:"postgres://"'},
      {id:'g22',label:'Email addresses indexed',q:'site:{target} intext:"@{target}" filetype:txt | filetype:csv | filetype:xls'},
      {id:'g23',label:'Cached & deleted pages',q:'cache:{target}'},
      {id:'g24',label:'Related / similar sites',q:'related:{target}'},
    ]
  },
  {
    id:'shodan', name:'Shodan', engines:['Shodan'],
    insight:'Shodan scans the internet continuously. Use org: or ssl: filters to pivot on the target organisation. Favicon hash pivoting finds assets not in any DNS record.',
    dorks:[
      {id:'sh1',label:'All hosts for org',q:'org:"{target}"'},
      {id:'sh2',label:'Hosts by ASN',q:'asn:AS{target}'},
      {id:'sh3',label:'Exposed MongoDB',q:'org:"{target}" port:27017 product:MongoDB'},
      {id:'sh4',label:'Exposed Elasticsearch',q:'org:"{target}" port:9200 product:Elasticsearch'},
      {id:'sh5',label:'Exposed Redis',q:'org:"{target}" port:6379 product:Redis'},
      {id:'sh6',label:'Open Docker daemon',q:'org:"{target}" port:2375 product:Docker'},
      {id:'sh7',label:'Kubernetes API server',q:'org:"{target}" port:6443 ssl.cert.subject.cn:kubernetes'},
      {id:'sh8',label:'Exposed RDP (3389)',q:'org:"{target}" port:3389 os:windows'},
      {id:'sh9',label:'Jenkins / CI exposed',q:'org:"{target}" http.title:"Dashboard [Jenkins]"'},
      {id:'sh10',label:'Grafana dashboards',q:'org:"{target}" http.title:"Grafana" port:3000'},
      {id:'sh11',label:'Exposed Jupyter notebooks',q:'org:"{target}" http.title:"Jupyter Notebook"'},
      {id:'sh12',label:'SSL cert pivot (subdomain)',q:'ssl.cert.subject.cn:"*.{target}"'},
      {id:'sh13',label:'SSL SAN pivot (all names)',q:'ssl:"*.{target}" 200'},
      {id:'sh14',label:'Favicon hash pivot',q:'org:"{target}" http.favicon.hash:{hash}'},
      {id:'sh15',label:'VPN / Citrix gateways',q:'org:"{target}" title:"Citrix Gateway" | title:"SSL VPN"'},
      {id:'sh16',label:'Fortinet / Palo Alto VPN',q:'org:"{target}" ssl http.title:"SSL VPN" product:Fortinet'},
      {id:'sh17',label:'Webcams & surveillance',q:'org:"{target}" port:554 | port:8080 title:"webcam"'},
      {id:'sh18',label:'FTP anonymous login',q:'org:"{target}" port:21 "230 Login successful" "anonymous"'},
      {id:'sh19',label:'SMTP / mail servers',q:'org:"{target}" port:25 product:Postfix | product:Exim'},
      {id:'sh20',label:'Apache Tomcat exposed',q:'org:"{target}" http.title:"Apache Tomcat"'},
      {id:'sh21',label:'Exposed Memcached',q:'org:"{target}" port:11211 product:Memcached'},
      {id:'sh22',label:'MQTT IoT brokers',q:'org:"{target}" port:1883 product:MQTT'},
    ]
  },
  {
    id:'fofa', name:'FOFA', engines:['FOFA'],
    insight:'FOFA is a Chinese internet asset search engine — excellent for finding Asian infrastructure, CDN origins, and assets missed by Shodan/Censys. Uses base64-encoded queries.',
    dorks:[
      {id:'fo1',label:'Domain header pivot',q:'domain="{target}"'},
      {id:'fo2',label:'All subdomains via cert',q:'cert="{target}"'},
      {id:'fo3',label:'IP range of org',q:'org="{target}"'},
      {id:'fo4',label:'Title-based asset search',q:'title="{target}" && country="US"'},
      {id:'fo5',label:'Exposed admin panels',q:'domain="{target}" && title="admin"'},
      {id:'fo6',label:'Exposed databases',q:'domain="{target}" && port="27017"'},
      {id:'fo7',label:'ICO favicon hash',q:'icon_hash="{hash}" && domain="{target}"'},
      {id:'fo8',label:'App framework fingerprint',q:'body="X-Powered-By" && domain="{target}"'},
      {id:'fo9',label:'Exposed login pages',q:'domain="{target}" && title="login"'},
      {id:'fo10',label:'API endpoints via header',q:'domain="{target}" && header="api"'},
      {id:'fo11',label:'Cloud storage buckets',q:'host=".s3.amazonaws.com" && body="{target}"'},
      {id:'fo12',label:'Old / staging TLS certs',q:'cert.subject.cn="staging.{target}"'},
    ]
  },
  {
    id:'censys', name:'Censys', engines:['Censys'],
    insight:'Censys provides the most accurate TLS certificate data for deep infrastructure mapping. The certificates.parsed.names field is gold for subdomain enumeration.',
    dorks:[
      {id:'ce1',label:'All hosts (parsed cert name)',q:'parsed.names: {target}'},
