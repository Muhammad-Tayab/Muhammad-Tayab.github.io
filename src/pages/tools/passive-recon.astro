    },
    {
      id:'cloud-assets', name:'Cloud & Storage Asset Discovery', engines:['Google','Shodan'],
      insight:'S3 buckets, Azure Blobs, and GCP Storage are common bug bounty findings. Misconfigured public buckets can expose PII, internal files, and API keys.',
      dorks:[
        {id:'cl1',label:'S3 buckets (direct)',q:'site:s3.amazonaws.com "{target}"'},
        {id:'cl2',label:'S3 \u2014 confidential docs',q:'site:s3.amazonaws.com "{target}" "confidential" | "internal" | "backup"'},
        {id:'cl3',label:'Azure Blob storage',q:'site:blob.core.windows.net "{target}"'},
        {id:'cl4',label:'GCP Storage',q:'site:storage.googleapis.com "{target}"'},
        {id:'cl5',label:'DigitalOcean Spaces',q:'site:digitaloceanspaces.com "{target}"'},
