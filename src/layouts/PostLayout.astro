---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  date?: string;
  tags?: string[];
  platform?: string;
  difficulty?: string;
  category?: string;
  excerpt?: string;
  backHref?: string;
  backLabel?: string;
  prevPost?: { slug: string; title: string };
  nextPost?: { slug: string; title: string };
}

const {
  title,
  date,
  tags = [],
  platform,
  difficulty,
  category,
  excerpt,
  backHref = '/',
  backLabel = '← Back',
  prevPost,
  nextPost,
} = Astro.props;

const difficultyColor: Record<string, string> = {
  Easy: 'green',
  Medium: 'yellow',
  Hard: 'red',
};
---
<BaseLayout title={`${title} | Tayab Bashir`} description={excerpt}>
  <Nav />
  <main class="post-main">
    <article class="post-container">
      <div class="post-header reveal">
        <a href={backHref} class="back-btn">{backLabel}</a>

        {platform && (
          <div class="post-meta-row">
            <span class="tag">{platform}</span>
            {difficulty && (
              <span class={`tag ${difficultyColor[difficulty] || ''}`}>{difficulty}</span>
            )}
            {category && <span class="tag">{category}</span>}
          </div>
        )}

        <h1 class="post-title">
          <span class="green">// </span>{title}
        </h1>

        {date && (
          <div class="post-date dim">
            <span class="green">$</span> date --iso — {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </div>
        )}

        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
        )}
      </div>

      <div class="terminal-divider">────────────────────────────────────────────────────</div>

      <div class="post-body reveal">
        <slot />
      </div>

      <div class="terminal-divider">────────────────────────────────────────────────────</div>

      <nav class="post-nav reveal">
        {prevPost ? (
          <a href={prevPost.slug} class="post-nav-btn">
            <span class="dim">← prev</span>
            <span>{prevPost.title}</span>
          </a>
        ) : <div></div>}
        {nextPost ? (
          <a href={nextPost.slug} class="post-nav-btn right">
            <span class="dim">next →</span>
            <span>{nextPost.title}</span>
          </a>
        ) : <div></div>}
      </nav>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .post-main {
    padding-top: 100px;
    min-height: 100vh;
  }

  .post-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .post-header {
    margin-bottom: 32px;
  }

  .back-btn {
    display: inline-block;
    color: var(--green);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(0,255,65,0.3);
    padding: 6px 14px;
    border-radius: 4px;
    margin-bottom: 24px;
    transition: background 0.2s, box-shadow 0.2s;
  }

  .back-btn:hover {
    background: var(--green-dim);
    box-shadow: 0 0 12px var(--green-glow);
    opacity: 1;
  }

  .post-meta-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .tag.yellow {
    background: rgba(255, 200, 0, 0.15);
    color: #FFC800;
    border-color: rgba(255, 200, 0, 0.2);
  }

  .post-title {
    font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--white);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .post-date {
    font-size: 0.8rem;
    margin-bottom: 12px;
  }

  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  /* ── Post body markdown styles ── */
  .post-body :global(h1),
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    color: var(--green);
    margin: 2rem 0 1rem;
    font-family: var(--font);
  }

  .post-body :global(h1) { font-size: 1.5rem; }
  .post-body :global(h2) { font-size: 1.25rem; border-bottom: 1px solid rgba(0,255,65,0.2); padding-bottom: 6px; }
  .post-body :global(h3) { font-size: 1.05rem; }

  .post-body :global(p) {
    color: var(--white);
    margin-bottom: 1.2rem;
    opacity: 0.85;
  }

  .post-body :global(code) {
    background: rgba(0, 255, 65, 0.08);
    border: 1px solid rgba(0, 255, 65, 0.2);
    color: var(--green);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: var(--font);
    font-size: 0.85em;
  }

  .post-body :global(pre) {
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(0, 255, 65, 0.2);
    border-radius: 8px;
    padding: 20px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--green);
    font-size: 0.85rem;
  }

  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
    opacity: 0.85;
  }

  .post-body :global(li) { margin-bottom: 4px; }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--green);
    padding-left: 16px;
    margin: 1.5rem 0;
    opacity: 0.7;
    font-style: italic;
  }

  .post-body :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--glass-border);
    margin: 1.5rem 0;
  }

  .post-body :global(a) {
    color: var(--green);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--glass-border);
    margin: 2rem 0;
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.85rem;
  }

  .post-body :global(th) {
    background: var(--green-dim);
    color: var(--green);
    padding: 10px 14px;
    text-align: left;
    border: 1px solid rgba(0,255,65,0.2);
  }

  .post-body :global(td) {
    padding: 8px 14px;
    border: 1px solid var(--glass-border);
    opacity: 0.85;
  }

  /* ── Post navigation ── */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 48px;
  }

  .post-nav-btn {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    color: var(--white);
    font-size: 0.82rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    opacity: 0.85;
  }

  .post-nav-btn.right {
    text-align: right;
  }

  .post-nav-btn:hover {
    border-color: rgba(0,255,65,0.3);
    box-shadow: 0 0 16px var(--green-glow);
    opacity: 1;
  }
</style>
